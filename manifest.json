{
  "manifest_version": 3,
  "name": "Simple Tab Manager",
  "version": "3.1.1",
  "description": "Sort tabs, merge windows, extract tabs by domain, and save tabs to CSV.",
  "permissions": [
    "tabs",
    "windows",
    "scripting",
    "identity",
    "storage"
  ],
  "host_permissions": [
    "*://*.bilibili.com/*",
    "*://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  }
}
